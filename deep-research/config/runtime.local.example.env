# Copy to runtime.local.env for a machine that should keep local runtime wiring.
# Do not commit runtime.local.env.

# Where final accepted research runs are synced for local Obsidian use.
export OBSIDIAN_VAULT="${OBSIDIAN_VAULT:-$HOME/.openclaw/deep-research-vault}"

# The live workspace that is allowed to auto-load runtime.local.env.
export OPENCLAW_LIVE_WORKSPACE="${OPENCLAW_LIVE_WORKSPACE:-$HOME/.openclaw/workspace-deep-research-master}"

# Optional local Feishu/Lark delivery wiring.
export OPENCLAW_CRON_JOBS_JSON="${OPENCLAW_CRON_JOBS_JSON:-$HOME/.openclaw/cron/jobs.json}"
export OPENCLAW_LARK_WRAPPER="${OPENCLAW_LARK_WRAPPER:-$HOME/.openclaw/workspace/scripts/lark-cli-openclaw.sh}"
export OPENCLAW_FEISHU_ACCOUNT_ID="${OPENCLAW_FEISHU_ACCOUNT_ID:-deep-research-master}"

# Optional explicit stage-report target. If empty, emit-stage-report.sh resolves
# the user from OPENCLAW_CRON_JOBS_JSON.
# export OPENCLAW_STAGE_REPORT_FEISHU_USER_ID=""
