# Copy this file to ragflow.local.env and fill in the values that match your local setup.

# Local RAGFlow HTTP entry.
export RAGFLOW_BASE_URL="http://127.0.0.1:9380"

# If your local RAGFlow instance requires an API key, set the env name referenced by
# ragflow_profiles.json here.
export RAGFLOW_API_KEY=""

# Folder sync helper used by scripts/sync-rag-reference-folders.sh.
# Keep this script inside the transferred workspace, or point this variable to
# the equivalent local helper in your OpenClaw installation.
export RAGFLOW_SYNC_SCRIPT="${RAGFLOW_SYNC_SCRIPT:-$HOME/.openclaw/workspace-deep-research-master/ragflow_local_kb/sync_folder_to_ragflow.sh}"

# RAGFlow container fallback and queue repair settings used by the folder sync
# helper when host HTTP access fails or stuck parsing tasks must be cleaned up.
export RAGFLOW_DOCKER_CONTAINER="${RAGFLOW_DOCKER_CONTAINER:-docker-ragflow-cpu-1}"
export RAGFLOW_REDIS_CONTAINER="${RAGFLOW_REDIS_CONTAINER:-docker-redis-1}"
export RAGFLOW_REDIS_DB="${RAGFLOW_REDIS_DB:-1}"
export RAGFLOW_REDIS_PASSWORD="${RAGFLOW_REDIS_PASSWORD:-}"
export RAGFLOW_TASK_GROUP="${RAGFLOW_TASK_GROUP:-rag_flow_svr_task_broker}"
export RAGFLOW_TASK_STREAMS="${RAGFLOW_TASK_STREAMS:-rag_flow_svr_queue rag_flow_svr_queue_1}"

# PDF parsing chain. RAGFlow runs inside Docker, so it reaches the host MinerU
# API through host.docker.internal. The local smoke checks the host URL.
export MINERU_API_BASE="${MINERU_API_BASE:-http://127.0.0.1:38886}"
export MINERU_APISERVER="${MINERU_APISERVER:-http://host.docker.internal:38886}"
export MINERU_BACKEND="${MINERU_BACKEND:-pipeline}"
export MINERU_DELETE_OUTPUT="${MINERU_DELETE_OUTPUT:-1}"
export USE_DOCLING="${USE_DOCLING:-false}"

# LM Studio is already reachable on this machine at 127.0.0.1:1234.
# Use these values inside RAGFlow's service_conf.yaml.template when you wire local models:
# - OpenAI-compatible base URL: http://host.docker.internal:1234/v1
# - Example embedding model on this machine: text-embedding-nomic-embed-text-v1.5
